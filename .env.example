# Copy this file to .env and fill in your values.
# Never commit .env to git.

# --- Twitch (required for Ingestion stage) ---
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# --- Anthropic (required for AI Scoring stage) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Google (required for Analytics, Drive backup, and Scout dashboard) ---
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/your-service-account-key.json
# GOOGLE_SHEETS_ID=your_spreadsheet_id_here
# GOOGLE_DRIVE_BACKUP_FOLDER_ID=your_drive_folder_id_here
# YOUTUBE_API_KEY=your_readonly_api_key_here   # Scout dashboard only (not for uploads)

# --- Distribution — YouTube Shorts ---
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=

# --- Distribution — TikTok ---
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# --- Distribution — Twitter/X ---
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# --- Distribution — Reddit ---
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=

# --- Audio copyright detection — ACRCloud (optional) ---
# ACRCLOUD_ACCESS_KEY=
# ACRCLOUD_ACCESS_SECRET=
# ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com

# --- Rank Looker — Tracker.gg (optional; only needed when rank_looker.mode: "api") ---
# TRACKER_GG_API_KEY=
