{
  "template_id": "fast_hype",
  "version": 2,
  "deprecated": false,
  "display_name": "FPS Clips v2",
  "description": "Minimalist professional vertical clip — punch-in zoom, Anton captions, vibrant-cinematic color. Clean look that works on any FPS highlight.",
  "created_at": "2026-04-10",

  "timeline": {
    "input_mode": "single",
    "target_duration_seconds": 25.0,
    "target_duration_strategy": "trim_end",
    "intro": {
      "enabled": false,
      "duration_seconds": 0,
      "asset_path": null
    },
    "outro": {
      "enabled": false,
      "duration_seconds": 0,
      "asset_path": null
    }
  },

  "captions": {
    "enabled": true,
    "source": "transcript",
    "style": {
      "font_family": "Anton",
      "font_size_px": 72,
      "font_color": "#FFFFFF",
      "stroke_color": "#000000",
      "stroke_width_px": 6,
      "background": {
        "enabled": false,
        "color": "#000000CC",
        "padding_px": 0
      },
      "alignment": "bottom_center",
      "word_highlight": {
        "enabled": true,
        "highlight_color": "#FF4500"
      }
    },
    "max_chars_per_line": 25,
    "max_lines_on_screen": 2,
    "static_lines": []
  },

  "visual_effects": {
    "vertical_fill": {
      "method": "blur_pillarbox",
      "blur_strength": 40
    },
    "zoom": {
      "enabled": true,
      "type": "punch_in",
      "intensity": 1.07,
      "duration_seconds": 0.15
    },
    "color_grade": {
      "enabled": true,
      "preset": "vibrant",
      "brightness": 0.05,
      "contrast": 0.08,
      "saturation": 0.15,
      "lut_path": null
    },
    "transitions": {
      "between_clips": "cut",
      "duration_seconds": 0.0
    },
    "overlays": [],
    "vignette": {
      "enabled": true,
      "intensity": 0.20
    },
    "film_grain": {
      "enabled": false,
      "intensity": 0.0
    },
    "chromatic_aberration": {
      "enabled": false,
      "intensity": 0.0
    },
    "flash_cuts": {
      "enabled": false,
      "color": "#FFFFFF",
      "duration_frames": 2
    }
  },

  "audio": {
    "background_music": {
      "enabled": false,
      "asset_path": null,
      "volume_db": -16.0,
      "fade_in_seconds": 0.5,
      "fade_out_seconds": 1.0,
      "loop": true
    },
    "original_audio": {
      "enabled": true,
      "volume_db": -2.0,
      "normalize": true
    },
    "ducking": {
      "enabled": true,
      "duck_level_db": -28.0,
      "attack_ms": 40,
      "release_ms": 200
    },
    "sound_effects": []
  },

  "output": {
    "resolution": {
      "width": 1080,
      "height": 1920
    },
    "aspect_ratio": "9:16",
    "fps": 60,
    "codec": "h264",
    "bitrate_kbps": 8000,
    "platform_targets": ["youtube_shorts", "tiktok", "instagram_reels"],
    "safe_zone": {
      "enabled": true,
      "top_percent": 8.0,
      "bottom_percent": 20.0,
      "left_percent": 3.0,
      "right_percent": 3.0
    }
  }
}
