{
  "template_id": "tutorial_tips",
  "version": 1,
  "deprecated": false,
  "display_name": "Tutorial & Tips v1",
  "description": "Instructional content with step labels, dense captions, and slow pacing — selected almost entirely by keyword signals from the transcript.",
  "created_at": "2026-04-05",

  "timeline": {
    "input_mode": "single",
    "target_duration_seconds": 90.0,
    "target_duration_strategy": "speed_ramp",
    "segments": [
      { "name": "intro", "duration_seconds": 3.0, "source": "static_asset" },
      { "name": "main", "duration_seconds": 82.0, "source": "clip" },
      { "name": "outro", "duration_seconds": 5.0, "source": "static_asset" }
    ],
    "intro": {
      "enabled": true,
      "duration_seconds": 3.0,
      "asset_path": null
    },
    "outro": {
      "enabled": true,
      "duration_seconds": 5.0,
      "asset_path": null
    }
  },

  "captions": {
    "enabled": true,
    "source": "transcript",
    "style": {
      "font_family": "Montserrat-Bold",
      "font_size_px": 48,
      "font_color": "#FFFFFF",
      "stroke_color": "#000000",
      "stroke_width_px": 2,
      "background": {
        "enabled": true,
        "color": "#000000AA",
        "padding_px": 10
      },
      "alignment": "bottom_center",
      "word_highlight": {
        "enabled": false,
        "highlight_color": "#FFFFFF"
      }
    },
    "max_chars_per_line": 35,
    "max_lines_on_screen": 3,
    "static_lines": [
      {
        "text": "Pro Tip",
        "start_seconds": 0.0,
        "end_seconds": 3.0,
        "position_override": "top_left"
      }
    ]
  },

  "visual_effects": {
    "vertical_fill": {
      "method": "blur_pillarbox",
      "blur_strength": 30
    },
    "zoom": {
      "enabled": true,
      "type": "slow_push",
      "intensity": 1.03,
      "duration_seconds": 2.0
    },
    "color_grade": {
      "enabled": true,
      "preset": "natural",
      "brightness": 0.05,
      "contrast": 0.08,
      "saturation": 0.0,
      "lut_path": null
    },
    "transitions": {
      "between_clips": "crossfade",
      "duration_seconds": 0.30
    },
    "overlays": [
      {
        "type": "text",
        "asset_path": null,
        "text_content": "Like for more tips",
        "position": "bottom_right",
        "size_percent": 8.0,
        "opacity": 0.85,
        "start_seconds": 85.0,
        "end_seconds": null
      }
    ],
    "vignette": {
      "enabled": true,
      "intensity": 0.20
    },
    "film_grain": {
      "enabled": false,
      "intensity": 0.0
    },
    "chromatic_aberration": {
      "enabled": false,
      "intensity": 0.0
    },
    "flash_cuts": {
      "enabled": false,
      "color": "#FFFFFF",
      "duration_frames": 1
    }
  },

  "audio": {
    "background_music": {
      "enabled": false,
      "asset_path": null,
      "volume_db": -24.0,
      "fade_in_seconds": 1.0,
      "fade_out_seconds": 2.0,
      "loop": true
    },
    "original_audio": {
      "enabled": true,
      "volume_db": 0.0,
      "normalize": true
    },
    "ducking": {
      "enabled": true,
      "duck_level_db": -40.0,
      "attack_ms": 30,
      "release_ms": 400
    },
    "sound_effects": []
  },

  "output": {
    "resolution": {
      "width": 1080,
      "height": 1920
    },
    "aspect_ratio": "9:16",
    "fps": 30,
    "codec": "h264",
    "bitrate_kbps": 6000,
    "platform_targets": ["youtube_shorts", "tiktok", "instagram_reels"],
    "safe_zone": {
      "enabled": true,
      "top_percent": 10.0,
      "bottom_percent": 22.0,
      "left_percent": 3.0,
      "right_percent": 3.0
    }
  }
}
