!quarantine/*/.gitkeep

processing/**
!processing/*/
!processing/*/.gitkeep

accepted/**
!accepted/*/
!accepted/*/.gitkeep

rejected/**
!rejected/*/
!rejected/*/.gitkeep

# Logs — keep folder, ignore log files
logs/**
!logs/.gitkeep

